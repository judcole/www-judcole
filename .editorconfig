# 2026-05-10	Editor configuration

# top-most EditorConfig file
root = true

[*]
charset = utf-8
indent_style = space
insert_final_newline = true
max_line_length=110
trim_trailing_whitespace = true

[*.js]
indent_size = 2

[*.{json,py}]
indent_size = 4

[*.{md,mdx}]
indent_size = 4

[Makefile]
indent_style = tab

[*.{toml,yaml,yml}]
indent_size = 2

