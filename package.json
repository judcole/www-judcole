{
    "name": "jc-portfolio",
    "version": "3.0.0",
    "description": "Jud Cole Personal Portfolio Website",
    "type": "module",
    "scripts": {
        "astro": "astro",
        "build": "astro build",
        "check": "eslint . && astro check && tsc --project tsconfig.json --noEmit",
        "clean": "rm -rf ./.astro && rm -rf dist/* && rm -rf node_modules && rm -rf pnpm-lock.yaml && rm -f *.lock && rm -f *.log",
        "dev": "astro dev",
        "format:check": "oxfmt --check . && prettier --check '**/*.astro'",
        "format:fix": "oxfmt --write . && prettier --write '**/*.astro'",
        "lint": "oxlint --type-aware",
        "lint:fix": "oxlint --type-aware --fix",
        "preview": "astro preview",
        "start": "astro dev",
        "update": "pnpm update --latest",
        "upgrade": "pnpm dlx @astrojs/upgrade"
    },
    "dependencies": {
        "@astrojs/mdx": "^5.0.3",
        "@astrojs/rss": "^4.0.18",
        "@astrojs/sitemap": "3.7.2",
        "@tailwindcss/vite": "^4.2.4",
        "astro": "^6.1.8",
        "astro-theme-toggle": "^0.8.0",
        "daisyui": "^5.5.19",
        "dayjs": "^1.11.20",
        "globals": "^17.5.0",
        "puppeteer": "^24.42.0",
        "sharp": "^0.34.5",
        "tailwindcss": "^4.2.4",
        "typescript": "^6.0.3"
    },
    "devDependencies": {
        "@astrojs/check": "^0.9.8",
        "@astrojs/ts-plugin": "^1.10.7",
        "@eslint/eslintrc": "^3.3.5",
        "@eslint/js": "^10.0.1",
        "@tailwindcss/typography": "^0.5.19",
        "@typescript-eslint/parser": "^8.59.0",
        "checkcss": "^2.0.9",
        "eslint": "^10.2.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-astro": "^1.7.0",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "oxfmt": "^0.46.0",
        "oxlint": "^1.61.0",
        "oxlint-tsgolint": "^0.21.1",
        "prettier": "^3.8.3",
        "prettier-plugin-astro": "^0.14.1",
        "prettier-plugin-organize-imports": "^4.3.0",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "typescript-eslint": "^8.59.0"
    },
    "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
    "pnpm": {
        "onlyBuiltDependencies": [
            "@tailwindcss/oxide",
            "esbuild",
            "puppeteer",
            "sharp"
        ]
    }
}
