{
    "name": "jc-portfolio",
    "description": "Jud Cole Personal Portfolio Website",
    "type": "module",
    "version": "3.0.0",
    "scripts": {
        "astro": "astro",
        "build": "astro build",
        "check": "astro check && tsc --project tsconfig.json --noEmit",
        "clean": "rm -rf ./.astro && rm -rf build/* && rm -rf node_modules && rm -rf pnpm-lock.yaml && rm -f *.lock && rm -f *.log",
        "dev": "astro dev",
        "format:check": "oxfmt --check .",
        "format:fix": "oxfmt --write .",
        "lint": "oxlint --type-aware",
        "lint:fix": "oxlint --type-aware --fix",
        "preview": "astro preview",
        "start": "astro dev",
        "update": "pnpm update --latest",
        "upgrade": "pnpm dlx @astrojs/upgrade"
    },
    "dependencies": {
        "@astrojs/mdx": "^4.3.13",
        "@astrojs/rss": "^4.0.15",
        "@astrojs/sitemap": "^3.7.0",
        "@tailwindcss/vite": "^4.2.0",
        "astro": "^5.17.3",
        "astro-theme-toggle": "^0.8.0",
        "daisyui": "5.5.19",
        "dayjs": "^1.11.19",
        "puppeteer": "^24.37.5",
        "sharp": "^0.34.5",
        "tailwindcss": "^4.2.0",
        "typescript": "^5.9.3"
    },
    "devDependencies": {
        "@astrojs/check": "^0.9.6",
        "@tailwindcss/typography": "^0.5.19",
        "@typescript-eslint/parser": "^8.56.0",
        "checkcss": "^2.0.9",
        "eslint": "^10.0.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-astro": "^1.6.0",
        "oxfmt": "^0.42.0",
        "oxlint": "^1.60.0",
        "oxlint-tsgolint": "^0.21.0",
        "prettier": "^3.8.1",
        "prettier-plugin-astro": "^0.14.1",
        "prettier-plugin-organize-imports": "^4.3.0",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "typescript-eslint": "^8.57.2"
    },
    "packageManager": "pnpm@10.30.1+sha512.3590e550d5384caa39bd5c7c739f72270234b2f6059e13018f975c313b1eb9fefcc09714048765d4d9efe961382c312e624572c0420762bdc5d5940cdf9be73a",
    "pnpm": {
        "onlyBuiltDependencies": [
            "@tailwindcss/oxide",
            "esbuild",
            "puppeteer",
            "sharp"
        ]
    }
}
