{
    "name": "jc-portfolio",
    "version": "3.0.0",
    "description": "Jud Cole Personal Portfolio Website",
    "type": "module",
    "scripts": {
        "astro": "astro",
        "build": "astro build",
        "check": "eslint . && astro check && tsc --project tsconfig.json --noEmit",
        "clean": "rm -rf ./.astro && rm -rf dist/* && rm -rf node_modules && rm -rf pnpm-lock.yaml && rm -f *.lock && rm -f *.log",
        "dev": "astro dev",
        "format:check": "oxfmt --check . && prettier --check '**/*.astro'",
        "format:fix": "oxfmt --write . && prettier --write '**/*.astro'",
        "lint": "oxlint --type-aware",
        "lint:fix": "oxlint --type-aware --fix",
        "preview": "astro preview",
        "scan": "cve-lite --all --verbose .",
        "start": "astro dev",
        "update": "pnpm update --latest",
        "upgrade": "pnpm dlx @astrojs/upgrade"
    },
    "dependencies": {
        "@astrojs/mdx": "^5.0.4",
        "@astrojs/rss": "^4.0.18",
        "@astrojs/sitemap": "3.7.2",
        "@tailwindcss/vite": "^4.3.0",
        "astro": "^6.3.1",
        "astro-theme-toggle": "^0.8.0",
        "daisyui": "^5.5.19",
        "dayjs": "^1.11.20",
        "globals": "^17.6.0",
        "puppeteer": "^24.43.0",
        "sharp": "^0.34.5",
        "tailwindcss": "^4.3.0",
        "typescript": "^6.0.3"
    },
    "devDependencies": {
        "@astrojs/check": "^0.9.9",
        "@astrojs/ts-plugin": "^1.10.7",
        "@eslint/eslintrc": "^3.3.5",
        "@eslint/js": "^10.0.1",
        "@tailwindcss/typography": "^0.5.19",
        "@typescript-eslint/parser": "^8.59.2",
        "checkcss": "^2.0.9",
        "eslint": "^10.3.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-astro": "^1.7.0",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "oxfmt": "^0.48.0",
        "oxlint": "^1.63.0",
        "oxlint-tsgolint": "^0.22.1",
        "prettier": "^3.8.3",
        "prettier-plugin-astro": "^0.14.1",
        "prettier-plugin-astro-organize-imports": "^0.4.12",
        "prettier-plugin-organize-imports": "^4.3.0",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "typescript-eslint": "^8.59.2",
        "vite": "^7.3.3"
    },
    "packageManager": "pnpm@11.0.9+sha512.34ce82e6780233cf9cad8685029a8f81d2e06196c5a9bad98879f7424940c6817c4e4524fb7d38b8553ceed48b9758b8ebaf1abd3600c232c4c8cf7366086f38",
    "pnpm": {
        "onlyBuiltDependencies": [
            "@tailwindcss/oxide",
            "esbuild",
            "puppeteer",
            "sharp"
        ],
        "overrides": {
            "yaml": "^2.8.3"
        }
    }
}
