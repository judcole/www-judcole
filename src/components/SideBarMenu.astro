---
const { sideBarActiveItemID } = Astro.props;
const activeClass = "bg-base-200"; // For primary color replace with `active` class
---

<script type="text/javascript">
    // <!-- Script to hide address
    function get_em(em) {
        return em + "&#64;jud" + "cole.com";
    }
    //-->
</script>

<ul class="menu menu-md w-full shrink grow overflow-y-auto">
    <li><a class="py-3 text-xl" id="home" href="/">Home</a></li>
    <li><a class="py-3 text-xl" id="resume" href="/resume/">Resume</a></li>
    <li><a class="py-3 text-xl" id="recommendations" href="/recommendations/">Recommendations</a></li>
    <li><a class="py-3 text-xl" id="books" href="/books/">Books</a></li>
    <li><a class="py-3 text-xl" id="projects" href="/projects/">Projects</a></li>
    <!-- <li>
        <a class="py-3 text-base" id="projects" href="/projects">Projects</a>
    </li> -->
    <!-- <li>
        <a class="py-3 text-base" id="services" href="/services">Services</a>
    </li> -->
    <!-- <li><a class="py-3 text-base" id="store" href="/store">Store</a></li> -->
    <li><a class="py-3 text-xl" id="blog" href="/blog/">Blog</a></li>

    <!-- Script to hide address -->
    <script is:inline type="text/javascript">
        var em = get_em("resume");
        document.writeln('<li><a class="py-3 text-xl" href="' + 
            "mail" + "to:" + em + '">' + "Email me for a resume" + 
            "<\/a><\/li>");
    </script>
</ul>

<script
    is:inline
    define:vars={{
        sideBarActiveItemID: sideBarActiveItemID,
        activeClass: activeClass,
    }}
>
    const activeItemElem = document.getElementById(sideBarActiveItemID);
    activeItemElem && activeItemElem.classList.add(activeClass);
</script>
