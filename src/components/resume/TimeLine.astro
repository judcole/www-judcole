---
const { company, link, subtitle, title } = Astro.props;
---

<div class="flex">
    <div class="education__time">
        <span class="bg-primary mt-1 block h-4 w-4 rounded-full"></span>
        <span class="education__line bg-primary block h-full w-0.5 translate-x-1.75"></span>
    </div>
    <div class="px-5">
        <h3 class="mb-1 font-semibold">
            {title}
            {
                company && (
                    <span>
                        at{" "}
                        {link ? (
                            <a href={link} target="_blank'">
                                {company}
                            </a>
                        ) : (
                            { company }
                        )}
                    </span>
                )
            }
        </h3>
        <span class="text-sm font-light">{subtitle}</span>
        <p class="my-2 text-justify">
            <slot />
        </p>
    </div>
</div>
