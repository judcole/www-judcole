---
// 2026-05-10   Jud Cole Portfolio Books page

// spell-checker: ignore architecting componentized residuality

import BaseLayout from "../layouts/BaseLayout.astro"
import HorizontalCard from "../components/HorizontalCard.astro"
---

<BaseLayout title="Books" sideBarActiveItemID="books">
    <div>
        <div class="mb-5 w-full text-3xl font-bold">Recently Read Books</div>
    </div>

    <HorizontalCard
        title="Laws of Software Engineering: Milan Milanovic"
        img="/book.svg"
        imgWidth="50"
        desc="63+ laws and principles of Software Engineering, each with its own chapter covering where the law came from, how it actually works, what it looks like in the real world, and how it connects to other laws in the book."
        url="https://www.amazon.com/gp/product/B0GXH5JYVP"
        badge="Reading"
    />
    <div class="divider my-0"></div>
    <HorizontalCard
        title="Geographically Distributed Agile Teams: Johanna Rothman and Mark Kilby"
        img="/book.svg"
        imgWidth="50"
        desc="In this book, Johanna and Mark take you back to agile and lean principles and help you think how your team can adapt their culture, practices, and virtual workspace to continuously deliver."
        url="https://pragprog.com/titles/d-rkteams/from-chaos-to-successful-distributed-agile-teams/"
    />

    <div>
        <div class="mt-5 mb-5 w-full text-3xl font-bold">Recommended Books</div>
    </div>

    <HorizontalCard
        title="Infrastructure as Code, Third Edition: Kief Morris"
        img="/book.svg"
        imgWidth="50"
        desc="We need to start moving beyond hand-crafted infrastructure code, which has left many of us with a sprawl of snowflake environments as code. This 3rd edition shares emerging patterns and practices for a more componentized, composable approach to infrastructure as code."
        url="https://infrastructure-as-code.com/book"
    />
    <div class="divider my-0"></div>
    <HorizontalCard
        title="Modern Software Engineering: Doing What Works to Build Better Software Faster: David Farley"
        img="/book.svg"
        imgWidth="50"
        desc="In Modern Software Engineering, continuous delivery pioneer David Farley helps software professionals think about their work more effectively, manage it more successfully, and genuinely improve the quality of their applications, their lives, and the lives of their colleagues."
        url="https://www.amazon.com/gp/product/B09GG6XKS4"
    />
    <div class="divider my-0"></div>
    <HorizontalCard
        title="The Hyperion Cantos 4-Book Bundle: Dan Simmons"
        img="/book.svg"
        imgWidth="50"
        desc="Hailed as “one of the finest achievements of modern science fiction” by The New York Times Book Review, The Hyperion Cantos is a triumphant odyssey into the heart of space and time."
        url="https://www.amazon.com/gp/product/B00JTZF124"
    />
    <div class="divider my-0"></div>

    <div>
        <div class="mt-5 mb-5 w-full text-3xl font-bold">Interesting Reads</div>
    </div>

    <HorizontalCard
        title="The Architects Paradox: Barry O'Reilly"
        img="/book.svg"
        imgWidth="50"
        desc="An introduction to philosophy for software engineers and architects that will help them understand their design process. This book helps to answer the question “Why are we like this?"
        url="https://leanpub.com/architectsparadox"
    />
    <div class="divider my-0"></div>
    <HorizontalCard
        title="Enshittification: Why Everything Suddenly Got Worse and What to Do About It: Cory Doctorow"
        img="/book.svg"
        imgWidth="50"
        desc="It’s not just you—the internet sucks now. It’s been enshittified. That was no accident, and it’s not gonna fix itself. Here’s how we’ll disenshittify it so we can have a new, good internet."
        url="https://www.amazon.com/gp/product/B0DQJ5TWB1"
    />
    <div class="divider my-0"></div>
    <HorizontalCard
        title="Residuality Theory: Barry O'Reilly"
        img="/book.svg"
        imgWidth="50"
        desc="Residues: Time, Change, and Uncertainty in Software Architecture."
        url="https://leanpub.com/residuality"
    />
    <div class="divider my-0"></div>
    <HorizontalCard
        title="Vibe Coding: Building Production-Grade Software With GenAI, Chat, Agents, and Beyond: Gene Kim and Steve Yegge"
